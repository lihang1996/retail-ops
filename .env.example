# 复制为 .env 后按需修改
APP_PORT=8090
DB_PUBLISH_PORT=3307
NODE_ENV=local

DB_HOST=mysql
DB_PORT=3306
DB_USER=retail
DB_PASSWORD=retail123
DB_ROOT_PASSWORD=rootpass
DB_NAME=retail_ops

JWT_SECRET=retail-ops-change-me-in-prod

# 容器启动时是否强制重新 seed（默认仅空库 seed 一次）
SEED_ON_START=false

# 冒烟测试（scripts/e2e-smoke.js）
SMOKE_BASE_URL=http://127.0.0.1:8090
SMOKE_ACCOUNT=admin@retail.demo
SMOKE_PASSWORD=demo123

# 可选 Redis
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
